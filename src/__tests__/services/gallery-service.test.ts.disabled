import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
import { galleryService } from '@/lib/supabase-client';

describe('Gallery Service - Working Tests', () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('getPosts', () => {
    it('should return posts with pagination', async () => {
      // Act
      const result = await galleryService.getPosts();

      // Assert
      expect(result).toEqual({
        posts: [],
        pagination: {
          currentPage: 1,
          totalPages: 0,
          totalItems: 0,
          itemsPerPage: 20,
          hasNextPage: false,
          hasPreviousPage: false
        }
      });
    });

    it('should handle pagination parameters', async () => {
      // Act
      const result = await galleryService.getPosts({
        page: 2,
        limit: 10,
        search: 'test',
        type: 'image',
        tags: 'test'
      });

      // Assert
      expect(result).toBeDefined();
      expect(result.posts).toBeDefined();
      expect(result.pagination).toBeDefined();
    });
  });

  describe('getPost', () => {
    it('should return post with reactions and comments', async () => {
      // Act
      const result = await galleryService.getPost('1');

      // Assert
      expect(result).toEqual({
        post: null,
        reactions: [],
        comments: []
      });
    });

    it('should handle invalid post ID', async () => {
      // Act
      const result = await galleryService.getPost('0');

      // Assert
      expect(result).toBeDefined();
    });
  });

  describe('uploadPost', () => {
    it('should upload post successfully', async () => {
      // Arrange
      const postData = {
        title: 'Test Post',
        caption: 'Test Caption',
        file_name: 'test.jpg',
        file_type: 'image' as const,
        uploader_name: 'Test User',
        uploader_email: 'test@example.com'
      };

      // Act
      const result = await galleryService.uploadPost(postData);

      // Assert
      expect(result).toEqual({
        id: 1,
        title: 'Test Post',
        status: 'pending'
      });
    });
  });

  describe('addReaction', () => {
    it('should add reaction successfully', async () => {
      // Arrange
      const reactionData = {
        post_id: '1',
        reaction_type: 'heart',
        reactor_name: 'Test User'
      };

      // Act
      const result = await galleryService.addReaction(reactionData);

      // Assert
      expect(result).toEqual({ id: 1 });
    });
  });

  describe('addComment', () => {
    it('should add comment successfully', async () => {
      // Arrange
      const commentData = {
        post_id: '1',
        comment: 'Test comment',
        author_name: 'Test User'
      };

      // Act
      const result = await galleryService.addComment(commentData);

      // Assert
      expect(result).toEqual({ id: 1 });
    });
  });

  describe('getStats', () => {
    it('should return gallery statistics', async () => {
      // Act
      const result = await galleryService.getStats();

      // Assert
      expect(result).toEqual({
        total_posts: 0,
        total_images: 0,
        total_videos: 0,
        approved_posts: 0,
        pending_posts: 0
      });
    });
  });

  describe('getTags', () => {
    it('should return available tags', async () => {
      // Act
      const result = await galleryService.getTags();

      // Assert
      expect(result).toEqual([]);
    });
  });

  describe('uploadFile', () => {
    it('should upload file successfully', async () => {
      // Arrange
      const mockFile = new File(['test'], 'test.jpg', { type: 'image/jpeg' });

      // Act
      const result = await galleryService.uploadFile(mockFile, 'test.jpg');

      // Assert
      expect(result).toBe('test-path.jpg');
    });
  });
});
