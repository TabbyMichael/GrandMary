import { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';
import { galleryService } from '@/lib/supabase-client';
import { supabase } from '@/lib/supabase-client';

// Mock Supabase client
vi.mock('@/lib/supabase-client', () => ({
  supabase: {
    from: vi.fn(() => mockSupabaseQueryBuilder),
    storage: {
      from: vi.fn(() => mockStorageBuilder)
    }
  }
}));

// Mock environment variables
vi.mock('@/lib/supabase-client', () => {
  const mockSupabase = {
    from: vi.fn(),
    storage: {
      from: vi.fn()
    }
  };
  
  return {
    supabase: mockSupabase,
    galleryService: {
      getPosts: vi.fn(),
      getPost: vi.fn(),
      uploadPost: vi.fn(),
      addReaction: vi.fn(),
      addComment: vi.fn(),
      getStats: vi.fn(),
      getTags: vi.fn(),
      uploadFile: vi.fn()
    }
  };
});

const mockSupabaseQueryBuilder = {
  select: vi.fn().mockReturnThis(),
  eq: vi.fn().mockReturnThis(),
  or: vi.fn().mockReturnThis(),
  contains: vi.fn().mockReturnThis(),
  order: vi.fn().mockReturnThis(),
  range: vi.fn().mockReturnThis(),
  single: vi.fn().mockReturnThis(),
  insert: vi.fn().mockReturnThis(),
  upsert: vi.fn().mockReturnThis(),
  not: vi.fn().mockReturnThis()
};

const mockStorageBuilder = {
  upload: vi.fn(),
  getPublicUrl: vi.fn()
};

describe('GalleryService - Supabase Client', () => {
  beforeEach(() => {
    vi.clearAllMocks();
    vi.spyOn(console, 'error').mockImplementation(() => {});
  });

  afterEach(() => {
    vi.restoreAllMocks();
  });

  describe('getPosts', () => {
    it('should fetch posts with default parameters', async () => {
      // Arrange
      const mockData = [
        { id: '1', title: 'Test Post', gallery_reactions: [{ count: 5 }], gallery_comments: [{ count: 2 }] }
      ];
      const mockCount = 1;
      
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: mockData, 
        error: null,
        count: mockCount 
      });

      // Act
      const result = await galleryService.getPosts();

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_posts');
      expect(mockSupabaseQueryBuilder.select).toHaveBeenCalledWith(
        expect.stringContaining('gallery_reactions(count)')
      );
      expect(mockSupabaseQueryBuilder.eq).toHaveBeenCalledWith('status', 'approved');
      expect(mockSupabaseQueryBuilder.eq).toHaveBeenCalledWith('is_public', true);
      expect(result).toEqual({
        posts: [{
          ...mockData[0],
          reaction_count: 5,
          comment_count: 2
        }],
        pagination: {
          currentPage: 1,
          totalPages: 1,
          totalItems: 1,
          itemsPerPage: 20,
          hasNextPage: false,
          hasPreviousPage: false
        }
      });
    });

    it('should handle search filtering correctly', async () => {
      // Arrange
      const searchQuery = 'test search';
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: [], 
        error: null,
        count: 0 
      });

      // Act
      await galleryService.getPosts({ search: searchQuery });

      // Assert
      expect(mockSupabaseQueryBuilder.or).toHaveBeenCalledWith(
        `title.ilike.%${searchQuery}%,caption.ilike.%${searchQuery}%`
      );
    });

    it('should handle tag filtering correctly', async () => {
      // Arrange
      const tags = 'family,memory,love';
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: [], 
        error: null,
        count: 0 
      });

      // Act
      await galleryService.getPosts({ tags });

      // Assert
      expect(mockSupabaseQueryBuilder.contains).toHaveBeenCalledWith('tags', ['family', 'memory', 'love']);
    });

    it('should handle pagination correctly', async () => {
      // Arrange
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: [], 
        error: null,
        count: 50 
      });

      // Act
      await galleryService.getPosts({ page: 2, limit: 10 });

      // Assert
      expect(mockSupabaseQueryBuilder.range).toHaveBeenCalledWith(10, 19);
    });

    it('should throw error when Supabase query fails', async () => {
      // Arrange
      const mockError = new Error('Database error');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: null, 
        error: mockError,
        count: null 
      });

      // Act & Assert
      await expect(galleryService.getPosts()).rejects.toThrow('Database error');
      expect(console.error).toHaveBeenCalledWith('Error fetching posts:', mockError);
    });

    it('should handle empty data gracefully', async () => {
      // Arrange
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: null, 
        error: null,
        count: 0 
      });

      // Act
      const result = await galleryService.getPosts();

      // Assert
      expect(result.posts).toEqual([]);
      expect(result.pagination.totalItems).toBe(0);
    });

    it('should handle boundary values for pagination', async () => {
      // Arrange
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: [], 
        error: null,
        count: 0 
      });

      // Act
      const result1 = await galleryService.getPosts({ page: 0, limit: 0 });
      const result2 = await galleryService.getPosts({ page: 999, limit: 999 });

      // Assert
      expect(result1.pagination.currentPage).toBe(0);
      expect(result2.pagination.currentPage).toBe(999);
    });
  });

  describe('getPost', () => {
    it('should fetch single post with reactions and comments', async () => {
      // Arrange
      const postId = 'test-post-id';
      const mockPost = { id: postId, title: 'Test Post' };
      const mockReactions = [{ reaction_type: 'heart', count: 5 }];
      const mockComments = [{ id: '1', commenter_name: 'John', comment_text: 'Great post!' }];

      mockSupabaseQueryBuilder.single
        .mockResolvedValueOnce({ data: mockPost, error: null })
        .mockResolvedValueOnce({ data: mockReactions, error: null })
        .mockResolvedValueOnce({ data: mockComments, error: null });

      // Act
      const result = await galleryService.getPost(postId);

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_posts');
      expect(mockSupabaseQueryBuilder.eq).toHaveBeenCalledWith('id', postId);
      expect(mockSupabaseQueryBuilder.eq).toHaveBeenCalledWith('status', 'approved');
      expect(result).toEqual({
        post: mockPost,
        reactions: mockReactions,
        comments: mockComments
      });
    });

    it('should throw error when post not found', async () => {
      // Arrange
      const postId = 'non-existent-post';
      const mockError = new Error('Post not found');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.getPost(postId)).rejects.toThrow('Post not found');
    });

    it('should handle missing reactions gracefully', async () => {
      // Arrange
      const postId = 'test-post-id';
      const mockPost = { id: postId, title: 'Test Post' };

      mockSupabaseQueryBuilder.single
        .mockResolvedValueOnce({ data: mockPost, error: null })
        .mockResolvedValueOnce({ data: null, error: null })
        .mockResolvedValueOnce({ data: [], error: null });

      // Act
      const result = await galleryService.getPost(postId);

      // Assert
      expect(result.reactions).toEqual([]);
      expect(result.comments).toEqual([]);
    });
  });

  describe('uploadPost', () => {
    it('should upload post with pending status', async () => {
      // Arrange
      const postData = {
        uploader_name: 'John Doe',
        title: 'Test Upload',
        file_name: 'test.jpg'
      };
      const mockResponse = { id: '1', ...postData, status: 'pending' };

      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: mockResponse, 
        error: null 
      });

      // Act
      const result = await galleryService.uploadPost(postData);

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_posts');
      expect(mockSupabaseQueryBuilder.insert).toHaveBeenCalledWith([{
        ...postData,
        status: 'pending'
      }]);
      expect(result).toEqual(mockResponse);
    });

    it('should handle upload errors', async () => {
      // Arrange
      const postData = { uploader_name: 'John Doe' };
      const mockError = new Error('Upload failed');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.uploadPost(postData)).rejects.toThrow('Upload failed');
    });
  });

  describe('addReaction', () => {
    it('should add reaction to post', async () => {
      // Arrange
      const postId = 'test-post-id';
      const reactionData = {
        reaction_type: 'heart',
        reactor_name: 'John Doe'
      };
      const mockResponse = { id: '1', post_id: postId, ...reactionData };

      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: mockResponse, 
        error: null 
      });

      // Act
      const result = await galleryService.addReaction(postId, reactionData);

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_reactions');
      expect(mockSupabaseQueryBuilder.upsert).toHaveBeenCalledWith([{
        post_id: postId,
        ...reactionData
      }]);
      expect(result).toEqual(mockResponse);
    });

    it('should handle duplicate reactions', async () => {
      // Arrange
      const postId = 'test-post-id';
      const reactionData = { reaction_type: 'heart', reactor_name: 'John Doe' };
      const mockError = new Error('Duplicate reaction');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.addReaction(postId, reactionData)).rejects.toThrow('Duplicate reaction');
    });
  });

  describe('getStats', () => {
    it('should fetch gallery statistics', async () => {
      // Arrange
      const mockStats = {
        total_posts: 100,
        total_images: 80,
        total_videos: 20,
        approved_posts: 95,
        pending_posts: 5,
        unique_uploaders: 50,
        total_storage_used: 1000000,
        average_file_size: 10000
      };

      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: mockStats, 
        error: null 
      });

      // Act
      const result = await galleryService.getStats();

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_posts');
      expect(mockSupabaseQueryBuilder.select).toHaveBeenCalledWith(
        expect.stringContaining('count(*) as total_posts')
      );
      expect(result).toEqual(mockStats);
    });

    it('should handle stats query errors', async () => {
      // Arrange
      const mockError = new Error('Stats query failed');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.getStats()).rejects.toThrow('Stats query failed');
    });
  });

  describe('getTags', () => {
    it('should fetch and count popular tags', async () => {
      // Arrange
      const mockData = [
        { tags: ['family', 'love'] },
        { tags: ['family', 'memory'] },
        { tags: ['love'] }
      ];

      mockSupabaseQueryBuilder.select.mockResolvedValue({ 
        data: mockData, 
        error: null 
      });

      // Act
      const result = await galleryService.getTags();

      // Assert
      expect(supabase.from).toHaveBeenCalledWith('gallery_posts');
      expect(mockSupabaseQueryBuilder.eq).toHaveBeenCalledWith('status', 'approved');
      expect(mockSupabaseQueryBuilder.not).toHaveBeenCalledWith('tags', 'is', null);
      expect(result).toEqual([
        { tag: 'family', count: 2 },
        { tag: 'love', count: 2 },
        { tag: 'memory', count: 1 }
      ]);
    });

    it('should handle empty tags array', async () => {
      // Arrange
      const mockData = [
        { tags: [] },
        { tags: null },
        { tags: ['family'] }
      ];

      mockSupabaseQueryBuilder.select.mockResolvedValue({ 
        data: mockData, 
        error: null 
      });

      // Act
      const result = await galleryService.getTags();

      // Assert
      expect(result).toEqual([{ tag: 'family', count: 1 }]);
    });

    it('should handle tags query errors', async () => {
      // Arrange
      const mockError = new Error('Tags query failed');
      mockSupabaseQueryBuilder.select.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.getTags()).rejects.toThrow('Tags query failed');
    });
  });

  describe('uploadFile', () => {
    it('should upload file to storage and return public URL', async () => {
      // Arrange
      const mockFile = new File(['test'], 'test.jpg', { type: 'image/jpeg' });
      const fileName = 'test-file';
      const mockUploadResponse = { path: 'gallery/test-file-123.jpg' };
      const mockPublicUrl = 'https://supabase.com/gallery/test-file-123.jpg';

      mockStorageBuilder.upload.mockResolvedValue({ 
        data: mockUploadResponse, 
        error: null 
      });
      mockStorageBuilder.getPublicUrl.mockReturnValue({ 
        data: { publicUrl: mockPublicUrl } 
      });

      // Act
      const result = await galleryService.uploadFile(mockFile, fileName);

      // Assert
      expect(supabase.storage.from).toHaveBeenCalledWith('gallery');
      expect(mockStorageBuilder.upload).toHaveBeenCalledWith(
        expect.stringMatching(/test-file-\d+\.jpg/),
        mockFile,
        { cacheControl: '3600', upsert: false }
      );
      expect(result).toEqual({
        path: mockUploadResponse.path,
        publicUrl: mockPublicUrl,
        ...mockUploadResponse
      });
    });

    it('should handle file upload errors', async () => {
      // Arrange
      const mockFile = new File(['test'], 'test.jpg');
      const fileName = 'test-file';
      const mockError = new Error('Upload failed');

      mockStorageBuilder.upload.mockResolvedValue({ 
        data: null, 
        error: mockError 
      });

      // Act & Assert
      await expect(galleryService.uploadFile(mockFile, fileName)).rejects.toThrow('Upload failed');
    });

    it('should generate unique file paths', async () => {
      // Arrange
      const mockFile = new File(['test'], 'test.jpg');
      const fileName = 'test-file';

      mockStorageBuilder.upload.mockResolvedValue({ data: { path: 'unique-path' }, error: null });
      mockStorageBuilder.getPublicUrl.mockReturnValue({ data: { publicUrl: 'test-url' } });

      // Act
      await galleryService.uploadFile(mockFile, fileName);

      // Assert
      const uploadCall = mockStorageBuilder.upload.mock.calls[0];
      const filePath = uploadCall[0];
      expect(filePath).toMatch(/test-file-\d+\.jpg/);
    });
  });

  describe('Security Tests', () => {
    it('should prevent SQL injection in search queries', async () => {
      // Arrange
      const maliciousSearch = "'; DROP TABLE gallery_posts; --";
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: [], error: null, count: 0 });

      // Act
      await galleryService.getPosts({ search: maliciousSearch });

      // Assert
      expect(mockSupabaseQueryBuilder.or).toHaveBeenCalledWith(
        `title.ilike.%${maliciousSearch}%,caption.ilike.%${maliciousSearch}%`
      );
      // The parameter should be properly escaped by Supabase client
    });

    it('should handle null/undefined inputs gracefully', async () => {
      // Arrange
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: [], error: null, count: 0 });

      // Act & Assert - Should not throw
      await expect(galleryService.getPosts({ 
        search: null, 
        tags: undefined, 
        type: null 
      })).resolves.toBeDefined();
    });

    it('should validate post ID format', async () => {
      // Arrange
      const invalidPostId = '';
      const mockError = new Error('Invalid post ID');
      mockSupabaseQueryBuilder.single.mockResolvedValue({ data: null, error: mockError });

      // Act & Assert
      await expect(galleryService.getPost(invalidPostId)).rejects.toThrow('Invalid post ID');
    });
  });

  describe('Performance Tests', () => {
    it('should complete getPosts within acceptable time', async () => {
      // Arrange
      const startTime = performance.now();
      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: [], 
        error: null, 
        count: 0 
      });

      // Act
      await galleryService.getPosts();

      // Assert
      const endTime = performance.now();
      const executionTime = endTime - startTime;
      expect(executionTime).toBeLessThan(1000); // Should complete within 1 second
    });

    it('should handle large datasets efficiently', async () => {
      // Arrange
      const largeDataset = Array.from({ length: 1000 }, (_, i) => ({
        id: i.toString(),
        title: `Post ${i}`,
        gallery_reactions: [{ count: Math.floor(Math.random() * 100) }],
        gallery_comments: [{ count: Math.floor(Math.random() * 50) }]
      }));

      mockSupabaseQueryBuilder.single.mockResolvedValue({ 
        data: largeDataset, 
        error: null, 
        count: 1000 
      });

      // Act
      const startTime = performance.now();
      const result = await galleryService.getPosts({ limit: 100 });
      const endTime = performance.now();

      // Assert
      expect(result.posts).toHaveLength(100);
      expect(endTime - startTime).toBeLessThan(2000); // Should handle large datasets within 2 seconds
    });
  });
});
