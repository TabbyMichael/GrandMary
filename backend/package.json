{
  "name": "everbloom-backend",
  "version": "1.0.0",
  "description": "Backend API for Everbloom Memorial Website",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "start:test": "npm run dev",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint . || true",
    "type-check": "tsc --noEmit || true",
    "build": "echo 'Backend build completed'",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "sqlite3": "^5.1.6",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "uuid": "^9.0.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/joi": "^17.2.3",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0"
  },
  "keywords": ["memorial", "tribute", "candle", "api"],
  "author": "Everbloom Family",
  "license": "MIT"
}
