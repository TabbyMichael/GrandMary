# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
# Primary: Supabase (recommended for production)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Backup: SQLite (fallback)
DB_PATH=./database/everbloom.db

# Local PostgreSQL (alternative backup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=everbloom
DB_USER=postgres
DB_PASSWORD=your-postgres-password

# Database Strategy
DB_PRIMARY=supabase  # 'supabase' or 'sqlite'
DB_FALLBACK_ENABLED=true

# JWT Secret (Generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (Change these for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Configuration
ENCRYPTION_KEY=your-encryption-key-here-32-bytes-long
PASSWORD_PEPPER=your-password-pepper-here-16-bytes-long

# MFA Configuration
MFA_ISSUER=Everbloom Memorial Platform
MFA_WINDOW=1

# Monitoring Configuration
SECURITY_MONITORING_ENABLED=true
ALERT_WEBHOOK_URL=your-webhook-url-for-alerts

# CORS Configuration
ALLOWED_ORIGINS=https://everbloom-memorial.netlify.app,https://www.everbloom-memorial.netlify.app
